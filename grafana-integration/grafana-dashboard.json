      "pluginVersion": "10.0.0",
      "targets": [
        {"expr": "loxprox_nginx_errors_recent{instance=\"loxprox-gateway\"}", "legendFormat": "Nginx Errors", "refId": "A"},
        {"expr": "loxprox_nginx_rate_limited_recent{instance=\"loxprox-gateway\"}", "legendFormat": "Rate Limited", "refId": "B"},
        {"expr": "loxprox_appsec_detections_total{instance=\"loxprox-gateway\"}", "legendFormat": "AppSec Detections", "refId": "C"}
      ],
      "title": "Gateway Events",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
