        {"expr": "loxprox_service_up{instance=\"loxprox-gateway\",service=\"crowdsec\"}", "refId": "A"}
      ],
      "title": "CrowdSec",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
