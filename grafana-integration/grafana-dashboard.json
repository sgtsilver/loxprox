      "pluginVersion": "10.0.0",
      "targets": [
        {"expr": "100 * (1 - ((node_memory_MemAvailable_bytes{instance=\"loxprox-gateway\"} or node_memory_MemFree_bytes{instance=\"loxprox-gateway\"}) / node_memory_MemTotal_bytes{instance=\"loxprox-gateway\"}))", "refId": "A"}
