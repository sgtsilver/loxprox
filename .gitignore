# Secrets and local configuration
.env
*.local
config.json
/etc/crowdsec/bouncers/*.yaml.local

# Deploy configuration — operator's per-host values. The tracked template is
# deploy.conf.example; the real file lives at /etc/loxprox/deploy.conf on the
# deployed VM. Never commit a populated copy that ended up in the repo by
# accident.
deploy.conf

# Local deployment artifacts — operator's production-specific files (real
# IPs, hostnames, webhook URLs, etc.). The repo's deploy.conf.example is the
# public template; the populated copies live in local-deployment/ for
# scp/rsync to the live VM. Anything in this dir is private by default.
local-deployment/

# Runtime files
*.pid
*.sock
*.socket

# Backups (generated on target systems)
backups/
gateway-backups/
*.tar.gz

