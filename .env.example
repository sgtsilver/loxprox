# ═══════════════════════════════════════════════════════════════════════════════
# LoxProx — Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Network ──────────────────────────────────────────────────────────────────
LOXONE_IP=192.168.1.100
LOXONE_PORT=80
GATEWAY_IP=192.168.1.50
LAN_SUBNET=192.168.1.0/24

# SSH allowed subnets (space-separated CIDRs)
SSH_ALLOWED_SUBNETS="192.168.1.0/24 10.0.0.0/24"

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQ_PER_SEC=10
RATE_LIMIT_BURST=100
RATE_LIMIT_CONN_PER_IP=20

# ── Alerting ─────────────────────────────────────────────────────────────────
# Discord webhook URL for security alerts
# Get yours at: https://support.discord.com/hc/en-us/articles/228383668
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: email for error spike alerts (leave empty to skip)
ALERT_EMAIL=

# ── AppSec ───────────────────────────────────────────────────────────────────
# CrowdSec AppSec mode: "monitor" or "enforce"
APPSEC_MODE=enforce

# ── CrowdSec Whitelist ───────────────────────────────────────────────────────
# IPs and CIDRs that CrowdSec will never block (space-separated)
# Include your monitoring services, VPN endpoints, etc.
CROWDSEC_WHITELIST="192.168.1.0/24 10.0.0.0/24"

# ── Maintenance ──────────────────────────────────────────────────────────────
# Auto-reboot time for kernel updates (24h format)
AUTOREBOOT_TIME=03:00
