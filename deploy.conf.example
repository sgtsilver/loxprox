# ═══════════════════════════════════════════════════════════════════════════════
# LoxProx — Deploy Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file holds all the values that used to live at the top of deploy.sh.
# Pulling them out of source code means upgrades (git pull + redeploy) no
# longer require re-editing the script every time.
#
# USAGE
# -----
#   First install:     sudo cp deploy.conf.example /etc/loxprox/deploy.conf
#                      sudo $EDITOR /etc/loxprox/deploy.conf
#                      sudo ./deploy.sh
#
#   Upgrading from v1.3.x or earlier without an /etc/loxprox/deploy.conf:
#                      sudo ./deploy.sh --bootstrap-config
#                      # Inspects live nftables / nginx / ip route, extracts
#                      # your current values, writes /etc/loxprox/deploy.conf,
#                      # asks you to confirm. Then run sudo ./deploy.sh normally.
#
#   Subsequent runs:   sudo ./deploy.sh
#                      # Sources /etc/loxprox/deploy.conf. If the file is
#                      # missing AND no live install is detected, it refuses
#                      # to run and tells you what to do.
#
# File location on the deployed VM:  /etc/loxprox/deploy.conf  (mode 0640 root)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Network & Target Device
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Loxone Miniserver IP address
#   How to find: Run ./detect-loxone.sh on this machine, or check your router's
#   DHCP lease table for a device named "Loxone" or with MAC starting EE:E0:00
#   Example: "192.168.1.100"
LOXONE_IP="192.168.1.100"

# [REQUIRED] Loxone port (Gen 1 = 80, Gen 2 = usually 80 with HTTPS redirect)
#   This is the port the Miniserver listens on INSIDE your LAN.
#   Do NOT change this unless you reconfigured the Miniserver itself.
LOXONE_PORT="80"

# [REQUIRED] This gateway's static IP address
#   This VM must have a static IP so router port forwarding doesn't break.
#   Example: "192.168.1.50"
#   How to set: Run ./set-static-ip.sh BEFORE this script if needed.
GATEWAY_IP="192.168.1.50"

# [REQUIRED] Your LAN subnet (CIDR notation)
#   This is the network range that can reach SSH and is whitelisted in CrowdSec.
#   Example: "192.168.1.0/24"
#   How to find: ip route | grep default → check your interface's network mask
LAN_SUBNET="192.168.1.0/24"

# [REQUIRED] SSH allowed subnets (bash array — space-separated quoted CIDRs)
#   Only IPs from these networks can connect via SSH.
#   NEVER add 0.0.0.0/0 here — that exposes SSH to the entire internet.
#   Add your home LAN, a site-to-site VPN, and any jump boxes.
#   Example: ("192.168.1.0/24" "192.168.100.0/24" "10.8.0.0/24")
SSH_ALLOWED_SUBNETS=("192.168.1.0/24" "10.0.0.0/24")

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Rate Limiting (defaults are safe for home automation)
# ═══════════════════════════════════════════════════════════════════════════════

# Nginx rate limits — how many requests per second each IP can make
#   10 req/s with burst 100 is tuned for Loxone's web UI (it loads many assets).
#   Lower this if you see abuse; raise it if legitimate users get 503 errors.
RATE_LIMIT_REQ_PER_SEC="10"
RATE_LIMIT_BURST="100"

# Maximum concurrent connections per IP
#   20 is generous for a home setup. Prevents connection exhaustion attacks.
RATE_LIMIT_CONN_PER_IP="20"

# Proxy timeouts — how long nginx waits for the Miniserver to respond
#   These values protect against slowloris attacks (attackers hold connections
#   open to exhaust resources). Do not increase above 30s.
PROXY_CONNECT_TIMEOUT="10"
PROXY_SEND_TIMEOUT="15"
PROXY_READ_TIMEOUT="15"
CLIENT_BODY_TIMEOUT="10"
CLIENT_HEADER_TIMEOUT="10"

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — CrowdSec AppSec WAF
# ═══════════════════════════════════════════════════════════════════════════════

# Enable the CrowdSec AppSec Web Application Firewall
#   true  = Every HTTP request is inspected for CVE exploit patterns before
#           reaching the Loxone. Blocks known attack tools automatically.
#   false = Skip AppSec (not recommended).
ENABLE_APPSEC="true"

# AppSec operating mode
#   "monitor" — AppSec logs suspicious requests but does NOT block them.
#               Use this for the first week to verify no false positives.
#   "enforce" — AppSec blocks matched requests with HTTP 403.
#               Use this after you're confident the rules work for your setup.
#   Switching modes: change the value and re-run ./deploy.sh (idempotent).
APPSEC_MODE="enforce"

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — CrowdSec Whitelist (trusted IPs that can never be banned)
# ═══════════════════════════════════════════════════════════════════════════════

# IPs and CIDR ranges that CrowdSec will NEVER block, even under attack.
#   Add your home LAN, VPN endpoints, uptime monitoring services, etc.
#   Format: "1.2.3.4" for single IPs, "192.168.1.0/24" for ranges.
CROWDSEC_WHITELIST_IPS=(
    "192.168.1.0/24"      # [REQUIRED] your local LAN
    "10.0.0.0/24"         # [optional] site-to-site / VPN network
    # "203.0.113.45"      # [optional] uptime monitoring service
    # "198.51.100.0/24"   # [optional] cloud provider IP range
)

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Alerting
# ═══════════════════════════════════════════════════════════════════════════════

# Discord webhook URL for real-time security alerts
#   Get a webhook URL from your Discord server:
#   1. Open Discord → Server Settings → Integrations → Webhooks
#   2. Create a webhook, copy the URL, paste it here.
#   3. Leave empty "" to disable Discord alerts entirely.
#   The script /opt/loxprox/discord-alert.sh uses this URL.
DISCORD_WEBHOOK_URL=""

# Email address for nginx error spike alerts (leave empty to skip)
#   Requires mailutils to be installed. Sends an email if nginx error log
#   grows by more than 100 lines in 15 minutes.
ALERT_EMAIL=""

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — TLS (HTTPS on the gateway via ACME / acme.sh)
# ═══════════════════════════════════════════════════════════════════════════════
#
# When enabled, deploy.sh installs acme.sh, requests a public certificate for
# TLS_DOMAIN via HTTP-01, installs it at /etc/loxprox/tls/, and switches the
# nginx :1080 listener from plain HTTP to HTTPS. Renewal runs via acme.sh's
# default cron (~daily) and reloads nginx automatically.
#
# Toggle anytime: edit `ENABLE_TLS`, re-run `sudo bash deploy.sh`. Off→on
# installs + mutates the site; on→off reverts the site mutation and disables
# the renewal cron. Cert files at /etc/loxprox/tls/ are kept so a later
# re-enable doesn't have to re-issue. Use `sudo bash deploy.sh --remove-tls`
# to fully nuke (cert files, acme.sh state, conf.d).
#
# Prerequisites (operator action, BEFORE setting ENABLE_TLS=true):
#   1. A public DNS A record pointing TLS_DOMAIN at your router's WAN IP.
#      (Dynamic DNS providers like selfhost.eu are fine — make sure the
#      hostname resolves before you flip the switch.)
#   2. A router port forward `WAN:80 → gateway:80` in addition to the
#      existing 1080 forward. The :80 listener on the gateway answers ONLY
#      `/.well-known/acme-challenge/` requests (everything else gets a 301
#      to https://$TLS_DOMAIN:1080$request_uri). The widened public surface
#      is just the challenge directory — same threat profile as any normal
#      Let's Encrypt setup.
#
# Manual operations:
#   sudo bash deploy.sh --renew-tls    # force renewal now (acme.sh --renew)
#   sudo bash deploy.sh --remove-tls   # full removal — cert + state + cron
#

# Enable HTTPS on :1080. Default: false (plain HTTP).
ENABLE_TLS="false"

# Fully-qualified domain name the cert is issued for.
#   Must already resolve publicly to your router's WAN IP.
#   Example: "loxprox.example.com" (or your dynamic-DNS hostname)
TLS_DOMAIN=""

# Account email registered with the ACME provider. Required by Let's Encrypt;
# some providers (ZeroSSL) require it for account creation.
TLS_EMAIL=""

# ACME server. Accepts: letsencrypt, letsencrypt_test, zerossl, buypass,
# buypass_test, sslcom, or a full ACME directory URL.
#   - "letsencrypt"      → Let's Encrypt production (recommended)
#   - "letsencrypt_test" → Let's Encrypt staging (use during initial setup
#                          to avoid hitting rate limits while debugging)
#   - "zerossl"          → ZeroSSL production (default in upstream acme.sh)
TLS_ACME_SERVER="letsencrypt"

# v2.0 — Secondary CA tried automatically when the primary --issue fails
# (CA outage, rate limit). acme.sh registers the ZeroSSL account on the fly
# using TLS_EMAIL — no manual EAB credentials needed. Set to "" to disable.
TLS_ACME_FALLBACK_SERVER="zerossl"

# Extra arguments passed through to `acme.sh --issue`. Empty by default.
#   Examples:
#     "--keylength ec-256"       # request an ECDSA cert instead of RSA
#     "--debug"                  # noisy logs during issuance
#     "--days 60"                # custom renewal threshold
TLS_ACME_EXTRA=""

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Tunnel (v2.0): zero-open-ports remote access via a relay VPS
# ═══════════════════════════════════════════════════════════════════════════════
#
# For connections where no port can be forwarded (CGNAT / DS-Lite). The
# gateway dials OUT to your own relay VPS (set up with
# tunnel-relay/install-relay.sh); the Loxone app connects to the relay's
# domain. No router configuration needed at all.
# Full runbook: docs/TUNNEL-SETUP.md
#
# NOTE: ENABLE_TUNNEL=true and ENABLE_TLS=true are mutually exclusive in
# v2.0 — with the tunnel, TLS terminates at the relay.
#
# Manual operations:
#   sudo bash deploy.sh --remove-tunnel   # full removal — binary, config, units
#

# Enable the frp tunnel. Default: false (classic router port-forward path).
ENABLE_TUNNEL="false"

# [REQUIRED if enabled] Relay VPS public IP or DNS name (the frps host).
TUNNEL_SERVER_ADDR=""

# frp control-channel port on the relay. Must match FRP_BIND_PORT there.
# The relay listens on this port number for BOTH tcp and quic (udp).
TUNNEL_SERVER_PORT="7000"

# Tunnel transport: "quic" (UDP; NAT-friendly, connection migration —
# recommended) or "tcp" (fallback for networks that drop UDP).
TUNNEL_PROTOCOL="quic"

# [REQUIRED if enabled] Shared tunnel secret — SAME value as TUNNEL_TOKEN in
# the relay's /etc/loxprox-relay/relay.conf. Generate: openssl rand -hex 32
TUNNEL_TOKEN=""

# Proxy name inside frp (cosmetic, shows up in frps logs).
TUNNEL_PROXY_NAME="loxone"

# Loopback-bound port on the relay that carries tunneled traffic to its
# nginx. Must match TUNNEL_REMOTE_PORT in the relay's relay.conf.
TUNNEL_REMOTE_PORT="8443"

# Public domain served by the relay (its RELAY_DOMAIN). Used by the tunnel
# watchdog for full-path health probes and printed in the deploy summary.
TUNNEL_PUBLIC_HOST=""

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Maintenance
# ═══════════════════════════════════════════════════════════════════════════════

# Time for automatic reboot after kernel security updates
#   Format: 24-hour clock, local time.
#   Example: "03:00" = 3 AM. Set to a time when no one uses the Loxone.
AUTOREBOOT_TIME="03:00"
